# Reference: <https://postmarketos.org/devicepkg>
maintainer=""
pkgname=device-google-lynx
pkgdesc="Google Pixel 7a"
pkgver=1
pkgrel=3
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	linux-google-lynx
	mkbootimg
	android-tools
	postmarketos-base
	postmarketos-base-downstream
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	modules-initfs
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
	# Create a dummy DTB since the kernel extraction script skipped building the Lynx dtb,
	# and mkbootimg requires the --dtb flag for header versions > 2 to not be empty.
	install -d "$pkgdir"/boot/dtbs
	touch "$pkgdir"/boot/dtbs/dummy.dtb
}

