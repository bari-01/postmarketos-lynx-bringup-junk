# Reference: <https://postmarketos.org/vendorkernel>
# Kernel config based on: arch/arm64/configs/lynx_defconfig

maintainer=""
pkgname=linux-google-lynx
pkgver=6.1.124
pkgrel=0
pkgdesc="Google Pixel 7a (Lynx) kernel"
arch="aarch64"
_carch="arm64"
_flavor="google-lynx"
url="https://github.com/google/kernel-lynx"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"
makedepends="
	bash
	bc
	bison
	devicepkg-dev
	findutils
	flex
	android-tools
	openssl-dev
	perl
	python3
	xz
	linux-headers
	elfutils-dev
	zlib-dev
	pahole
"

# Source
# The kernel source tarball is the out/lynx-kernel tree produced by extract_lynx.sh.
# To host locally for development:  ./package_lynx.sh && python3 -m http.server 8080
# Replace _tarball_url with a real URL once hosted (e.g. GitHub release, self-hosted).
_tarball_url="http://10.20.50.113:8080/${pkgname}-${pkgver}.tar.gz"
_config="config-$_flavor.$arch"

source="
	${pkgname}-${pkgver}.tar.gz::${_tarball_url}
	$_config
"
_outdir="out"

prepare() {
	default_prepare

	# Fix missing asm headers for host tools (like resolve_btfids)
	# by linking to the chroot's native headers.
	rm -rf "$builddir/tools/include/uapi/asm"
	ln -sf /usr/include/asm "$builddir/tools/include/uapi/asm"

	make ARCH=arm64 mrproper
	# REPLACE_GCCH=0 prevents breaking compiler-gcc.h on modern kernels
	REPLACE_GCCH=0 . downstreamkernel_prepare
}

build() {
	unset LDFLAGS
	make -j24 O="$_outdir" ARCH="$_carch" CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-postmarketOS"
}

package() {
	downstreamkernel_package "$builddir" "$pkgdir" "$_carch" \
		"$_flavor" "$_outdir"
	make dtbs_install O="$_outdir" ARCH="$_carch" \
		INSTALL_DTBS_PATH="$pkgdir/boot/dtbs"
}

